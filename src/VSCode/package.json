{
  "name": "reqnroll-ide-support",
  "displayName": "Reqnroll IDE Support",
  "description": "[Experimental] Gherkin language support for Reqnroll — syntax highlighting, diagnostics, step navigation, completion, and more via the Reqnroll LSP server.",
  "version": "0.1.0",
  "publisher": "reqnroll",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "gherkin",
    "cucumber",
    "specflow",
    "reqnroll",
    "bdd",
    "feature"
  ],
  "activationEvents": [
    "onLanguage:gherkin",
    "onLanguage:plaintext",
    "workspaceContains:**/*.feature"
  ],
  "contributes": {
    "languages": [
      {
        "id": "gherkin",
        "aliases": [
          "Gherkin",
          "Feature",
          "SpecFlow",
          "Reqnroll"
        ],
        "extensions": [
          ".feature"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gherkin",
        "scopeName": "text.gherkin.feature",
        "path": "./syntaxes/gherkin.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "reqnroll.toggleComment",
        "title": "Reqnroll: Toggle Comment"
      },
      {
        "command": "reqnroll.findStepUsages",
        "title": "Reqnroll: Find Step Usages"
      },
      {
        "command": "reqnroll.findUnusedStepDefinitions",
        "title": "Reqnroll: Find Unused Step Definitions"
      },
      {
        "command": "reqnroll.goToHooks",
        "title": "Reqnroll: Go to Hooks"
      },
      {
        "command": "reqnroll.showOutputChannel",
        "title": "Reqnroll: Show Output Channel"
      },
      {
        "command": "reqnroll.goToStepDefinition",
        "title": "Reqnroll: Go to Step Definition"
      },
      {
        "command": "reqnroll.defineSteps",
        "title": "Reqnroll: Define Steps"
      },
      {
        "command": "reqnroll.renameStep",
        "title": "Reqnroll: Rename Step"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+/",
        "mac": "cmd+/",
        "command": "reqnroll.toggleComment",
        "when": "editorTextFocus && editorLangId == gherkin"
      },
      {
        "key": "f12",
        "command": "reqnroll.goToStepDefinition",
        "when": "editorTextFocus && editorLangId == gherkin"
      },
      {
        "key": "f2",
        "command": "reqnroll.renameStep",
        "when": "editorTextFocus && editorLangId == gherkin"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "reqnroll.toggleComment",
          "when": "editorLangId == gherkin",
          "group": "1_modification"
        },
        {
          "command": "reqnroll.goToHooks",
          "when": "editorLangId == gherkin",
          "group": "navigation@90"
        },
        {
          "command": "reqnroll.findStepUsages",
          "when": "editorLangId == csharp",
          "group": "navigation@90"
        },
        {
          "command": "reqnroll.defineSteps",
          "when": "editorLangId == gherkin",
          "group": "1_modification@10"
        },
        {
          "command": "reqnroll.renameStep",
          "when": "editorLangId == gherkin",
          "group": "1_modification@20"
        }
      ],
      "commandPalette": [
        {
          "command": "reqnroll.toggleComment",
          "when": "editorLangId == gherkin"
        },
        {
          "command": "reqnroll.goToHooks",
          "when": "editorLangId == gherkin"
        },
        {
          "command": "reqnroll.findStepUsages",
          "when": "editorLangId == csharp"
        },
        {
          "command": "reqnroll.goToStepDefinition",
          "when": "editorLangId == gherkin"
        },
        {
          "command": "reqnroll.defineSteps",
          "when": "editorLangId == gherkin"
        },
        {
          "command": "reqnroll.renameStep",
          "when": "editorLangId == gherkin"
        }
      ]
    },
    "configuration": {
      "title": "Reqnroll",
      "properties": {
        "reqnroll.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces the communication between VS Code and the Reqnroll LSP server, and also controls the server's own log verbosity ('off' -> Warning, 'messages' -> Info, 'verbose' -> Verbose). When set to 'verbose', a log file is also written to the Reqnroll log directory. Requires a window reload to take effect on the running server."
        }
      }
    },
    "configurationDefaults": {
      "[gherkin]": {
        "editor.defaultFormatter": "reqnroll.reqnroll-ide-support",
        "editor.formatOnType": true
      }
    },
    "semanticTokenScopes": [
      {
        "language": "gherkin",
        "scopes": {
          "reqnroll.keyword": [
            "keyword.control.gherkin"
          ],
          "reqnroll.tag": [
            "entity.name.tag.gherkin"
          ],
          "reqnroll.description": [
            "markup.raw.gherkin"
          ],
          "reqnroll.comment": [
            "comment.line.gherkin"
          ],
          "reqnroll.doc_string": [
            "string.quoted.other.gherkin"
          ],
          "reqnroll.data_table": [
            "markup.table.gherkin"
          ],
          "reqnroll.data_table_header": [
            "markup.table.header.gherkin"
          ],
          "reqnroll.step_parameter": [
            "variable.parameter.gherkin"
          ],
          "reqnroll.scenario_outline_placeholder": [
            "variable.other.placeholder.gherkin"
          ],
          "reqnroll.undefined_step": [
            "invalid.deprecated.gherkin"
          ],
          "reqnroll.ambiguous_step": [
            "markup.raw.ambiguous.gherkin"
          ]
        }
      }
    ]
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "build:server": "bash scripts/publish-server.sh",
    "build:vsix": "bash scripts/build-vsix.sh",
    "validate:tokens": "node scripts/validate-semantic-token-scopes.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "~1.96.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0",
    "mocha": "^11.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/clrudolphi/Reqnroll.Plugin.VisualStudio_Prototypes.git"
  },
  "dependencies": {
    "@vscode/extension-telemetry": "^1.5.2",
    "vscode-languageclient": "^10.0.1"
  }
}
