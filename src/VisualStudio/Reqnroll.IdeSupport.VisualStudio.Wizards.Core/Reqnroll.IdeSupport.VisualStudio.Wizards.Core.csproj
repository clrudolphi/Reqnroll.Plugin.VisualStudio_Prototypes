<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>10.0</LangVersion>
    <RootNamespace>Reqnroll.IdeSupport.VisualStudio.Wizards</RootNamespace>
    <AssemblyName>Reqnroll.IdeSupport.VisualStudio.Wizards.Core</AssemblyName>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\..\reqnroll.snk</AssemblyOriginatorKeyFile>
    <!--
      Intentionally targets netstandard2.0 so that:
        - net481 (the VSSDK extension host) can consume it
        - net8.0/net9.0 unit test projects can reference it without
          WPF or VS SDK transitive dependencies
      No UseWPF, no VS SDK package references permitted here.
    -->
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Core\Reqnroll.IdeSupport.Common\Reqnroll.IdeSupport.Common.csproj" />
  </ItemGroup>

</Project>
