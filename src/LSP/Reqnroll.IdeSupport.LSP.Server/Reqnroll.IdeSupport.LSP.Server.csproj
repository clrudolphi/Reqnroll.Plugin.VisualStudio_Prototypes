<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MediatR.Extensions.Microsoft.DependencyInjection" Version="8.*" />
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.FileSystemGlobbing" Version="9.0.0" />
    <PackageReference Include="OmniSharp.Extensions.LanguageServer" Version="0.19.9" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Reqnroll.IdeSupport.LSP.Core\Reqnroll.IdeSupport.LSP.Core.csproj" />
  </ItemGroup>

  <!-- Expose internal workspace/project mutators (Update, AddOrUpdateProject, RemoveProject)
       to the unit-test assembly.  The friend assembly is strong-named with reqnroll.snk, so
       the public key (same key used across the solution) is required here. -->
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Reqnroll.IdeSupport.LSP.Server.Tests, </_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Reqnroll.IdeSupport.LSP.Server.Specs, </_Parameter1>
    </AssemblyAttribute>
    <!-- Benchmark harness hosts the server in-process via Program.ConfigureServer (internal). -->
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Reqnroll.IdeSupport.LSP.Server.Benchmarks.Core, </_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <!-- Build-order dependency on the multi-targeted connector.
       ProjectReference cannot be used here because multi-targeted projects (.csproj with
       <TargetFrameworks>) do not expose the "GetTargetPath" MSBuild target at the outer
       build level, causing MSB4057 when the server (single-targeted) tries to reference them.
       An explicit MSBuild task call in a BeforeTargets="Build" target is the correct
       pattern: it triggers the connector's outer build, which dispatches each TFM inner
       build and runs CustomAfterBuild (which stages the connector outputs into this
       project's Connectors\ output folder) before this project begins compiling. -->
  <!-- RuntimeIdentifier/SelfContained are global properties: when the server itself is
       published self-contained for a specific RID, MSBuild would otherwise leak those
       into the connector's nested build below. The connector is always a
       framework-dependent, per-TFM build regardless of which RID the server targets
       (see docs on _ConnectorServerRid in Connector.csproj), so they're cleared here
       and the RID is instead threaded through via _ConnectorServerRid, which only
       affects where the build output is staged. -->
  <Target Name="BuildConnector" BeforeTargets="Build">
    <MSBuild Projects="$(MSBuildThisFileDirectory)..\Reqnroll.IdeSupport.LSP.Connector\Connector\Connector.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);_ConnectorServerRid=$(RuntimeIdentifier);RuntimeIdentifier=;SelfContained=false" />
  </Target>

  <!-- Copy Connector binaries into the publish output so reflection-based binding
       discovery can find the correct TFM-specific connector at runtime.  The
       BuildConnector target (above) stages them to $(OutputPath)Connectors\, but
       dotnet publish does not treat that as a standard publish item. -->
  <Target Name="CopyConnectorsToPublish" AfterTargets="CopyFilesToPublishDirectory">
    <ItemGroup>
      <_ConnectorFiles Include="$(MSBuildProjectDirectory)\$(OutputPath)Connectors\**" />
    </ItemGroup>
    <Copy SourceFiles="@(_ConnectorFiles)"
          DestinationFolder="$(PublishDir)Connectors\%(RecursiveDir)"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
